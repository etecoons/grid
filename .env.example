# Server Configuration
# The port number the backend HTTP server will bind to.
PORT=4405

# The application base URL, essential when deploying behind reverse proxies.
BASE_URL=http://localhost:4405

# Application Settings
# Custom website title rendered in navigation headers, browser tabs, etc.
SITE_TITLE=Grid

# Security: PIN Protection (4-64 characters, leave empty to disable)
# Optional PIN to restrict access to the Kanban board interface.
GRID_PIN=

# CORS Configuration
# Comma-separated list of allowed HTTP request origins. Use * to allow all.
ALLOWED_ORIGINS=*

# Timezone Configuration
# The timezone used for container logs and timestamps.
TZ=UTC

# Application Specific Settings
# The environment stage, such as production or development.
NODE_ENV=production

# Translation & Rate Limiting
# Enable the multi-language/translation selector in the navigation header.
ENABLE_TRANSLATION=false

# Number of failed PIN authentication attempts permitted before IP lockout.
MAX_ATTEMPTS=5
