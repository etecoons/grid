<?xml version="1.0"?>
<Container version="2">
  <Name>grid</Name>
  <Repository>ghcr.io/studio2201/grid:latest</Repository>
  <Registry>https://ghcr.io/studio2201/grid</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/grid/issues</Support>
  <Project>https://github.com/studio2201/grid</Project>
  <Overview>Distributed cluster management, node health, and file grid dashboard built in Rust.</Overview>
  <Category>Tools: System Network:Management</Category>
  <WebUI>http://[IP]:[PORT:4405]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/grid.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/grid.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Distributed cluster management, node health, and file grid dashboard built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4405</HostPort>
        <ContainerPort>4405</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/grid</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4405</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4405" Default="4405" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4405</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/grid" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/grid</Config>
</Container>
